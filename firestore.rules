rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // First Rule: Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable global primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation helpers
    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'email'])
        && data.uid == request.auth.uid
        && data.email is string
        && (!('displayName' in data) || data.displayName is string)
        && (!('photoURL' in data) || data.photoURL is string)
        && (!('language' in data) || data.language in ['ar', 'en'])
        && (!('theme' in data) || data.theme in ['dark', 'light']);
    }

    function isValidReport(data) {
      return data.keys().hasAll(['id', 'userId', 'type', 'timestamp'])
        && data.id is string
        && data.userId == request.auth.uid
        && data.type in ['login', 'text-to-image', 'image-to-video', 'text-to-speech']
        && data.timestamp is string;
    }

    // Mappings and matching rules
    match /users/{userId} {
      allow get: if isSignedIn();
      allow create, update: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow delete: if isOwner(userId);
    }

    match /reports/{reportId} {
      allow create: if isSignedIn() && isValidId(reportId) && isValidReport(request.resource.data);
      allow read: if isSignedIn();
    }
  }
}
