{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile with their settings and role data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "language": { "type": "string", "enum": ["ar", "en"] },
        "theme": { "type": "string", "enum": ["dark", "light"] },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Report": {
      "title": "Report",
      "description": "Activity logs and conversion reports directly visible on the admin dashboard",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userDisplayName": { "type": "string" },
        "type": { "type": "string", "enum": ["login", "text-to-image", "image-to-video", "text-to-speech"] },
        "prompt": { "type": "string" },
        "resultUrl": { "type": "string" },
        "timestamp": { "type": "string" },
        "language": { "type": "string" }
      },
      "required": ["id", "userId", "type", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User configuration document mapped by UID"
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Activity history tracking logs"
    }
  }
}
